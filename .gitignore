# Upstream default is to ignore inventory locally. Use the `/*` form here so
# this fork can deliberately re-include a small tracked subset.
/inventory/*
!/inventory/host_vars/

# Fork-local tracked inventory exceptions. Keep this block isolated so future
# upstream merges only need to preserve these explicit re-includes.
/inventory/host_vars/*
!/inventory/host_vars/domain/
!/inventory/host_vars/domain/**
!/inventory/host_vars/domain-immich-deps/
!/inventory/host_vars/domain-immich-deps/**
!/inventory/host_vars/domain-nextcloud-deps/
!/inventory/host_vars/domain-nextcloud-deps/**

# ignore files created by running pre-commit locally
.ansible

/requirements.yml
/setup.yml
/group_vars/mash_servers

/run/*
!/run/.gitkeep

/var/

/group_vars/*
!/group_vars/.gitkeep

# ignore roles pulled by ansible-galaxy
/roles/galaxy/*
!/roles/galaxy/.gitkeep

# Ignore temp files
.gitignore.swp
*.bak
.venv/
**/.venv/
venv/
**/venv/

# ignores vscode file
.vscode

# ignores macos files
.DS_Store
